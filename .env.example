# ==============================================================================
# PROPLAYER - DOTENV CONFIGURATION
# ==============================================================================
# This file serves as a template. Do NOT put real passwords or tokens here.
# Copy this file to '.env' and fill in the values for your local development.
# The '.env' file is explicitly ignored in .gitignore to prevent token leaks.

# ------------------------------------------------------------------------------
# Analytics & Crashlytics (e.g., Sentry, Firebase)
# ------------------------------------------------------------------------------
SENTRY_DSN=your_sentry_dsn_here
CRASHLYTICS_API_KEY=your_crashlytics_api_key_here

# ------------------------------------------------------------------------------
# Feature Flags (Boolean format: true/false)
# ------------------------------------------------------------------------------
ENABLE_DEBUG_MENU=true
ENABLE_BETA_FEATURES=false

# ------------------------------------------------------------------------------
# Remote Config / API Keys (If integrating cloud sync in the future)
# ------------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------------------------------------------
# Code Signing (Local Build Environment)
# ------------------------------------------------------------------------------
DEVELOPMENT_TEAM_ID=your_apple_team_id
